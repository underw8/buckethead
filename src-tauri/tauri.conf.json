{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AWSThathoo",
  "version": "1.2.0",
  "identifier": "com.awsthathoo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AWS Thathoo",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' asset: https://*.s3.amazonaws.com https://*.s3-accelerate.amazonaws.com data: blob:; frame-src 'self' asset: https://*.s3.amazonaws.com https://*.s3-accelerate.amazonaws.com; connect-src https:"
    }
  },
  "plugins": {
    "updater": {
      "__comment": "Replace PLACEHOLDER_PUBLIC_KEY with the output of: tauri signer generate -w ~/.tauri/awsthathoo.key",
      "pubkey": "PLACEHOLDER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/underw8/aws-thathoo/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  }
}
